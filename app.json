{
  "expo": {
    "name": "FideliApp",
    "slug": "fideliapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fideliapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B2B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fideliapp.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para escanear códigos QR de clientes.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a la galería para subir imágenes de perfil."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.fideliapp.app",
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tu galería para subir el logo e imagen de fondo de tu negocio."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Necesitamos acceso a la cámara para escanear códigos QR."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B2B",
          "defaultChannel": "default"
        }
      ],
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e8cf740e-b9dc-4b8a-ab44-9716b4899f2c"
      }
    },
    "owner": "carlesteruel"
  }
}
